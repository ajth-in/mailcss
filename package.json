{
  "name": "emailcss",
  "version": "0.0.0",
  "description": " A lightweight, type-safe CSS-in-JS solution designed specifically for React Email.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <ajithpmuralidharan01@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajth-in/emailcss.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "email:dev": "email dev",
    "build": "pnpm run prebuild && vp pack",
    "prebuild": "pnpm run gen-property-map && pnpm run gen-types",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "prepare": "vp config",
    "gen-property-map": "tsx src/can-i-email/index.ts",
    "gen-types": "tsx src/scripts/generate-types.ts"
  },
  "dependencies": {
    "@react-email/components": "1.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "react-email": "5.2.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
